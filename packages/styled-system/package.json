{
  "name": "@infernal-ui/styled-system",
  "version": "0.1.0-next.1",
  "description": "Generated Panda styled-system package for Infernal UI recipes, tokens, themes, and helpers.",
  "keywords": [
    "panda-css",
    "styled-system",
    "design-system",
    "solid",
    "css-in-js",
    "infernal-ui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Drummss/infernal-ui.git",
    "directory": "packages/styled-system"
  },
  "homepage": "https://github.com/Drummss/infernal-ui/tree/main/packages/styled-system#readme",
  "bugs": {
    "url": "https://github.com/Drummss/infernal-ui/issues"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "css",
    "jsx",
    "patterns",
    "recipes",
    "themes",
    "tokens",
    "types",
    "helpers.mjs",
    "styles.css"
  ],
  "exports": {
    "./css": {
      "types": "./css/index.d.ts",
      "import": "./css/index.mjs"
    },
    "./jsx": {
      "types": "./jsx/index.d.ts",
      "import": "./jsx/index.mjs"
    },
    "./patterns": {
      "types": "./patterns/index.d.ts",
      "import": "./patterns/index.mjs"
    },
    "./recipes": {
      "types": "./recipes/index.d.ts",
      "import": "./recipes/index.mjs"
    },
    "./themes": {
      "types": "./themes/index.d.ts",
      "import": "./themes/index.mjs"
    },
    "./tokens": {
      "types": "./tokens/index.d.ts",
      "import": "./tokens/index.mjs"
    },
    "./types": {
      "types": "./types/index.d.ts",
      "import": "./types/index.d.ts"
    },
    "./styles.css": "./styles.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "node ../../scripts/clean-paths.mjs css jsx patterns recipes themes tokens types helpers.mjs styles.css",
    "dev": "node ../../scripts/run-parallel.mjs \"panda codegen --watch\" \"panda cssgen --watch --outfile styles.css\"",
    "build": "pnpm run clean && panda codegen && panda cssgen --outfile styles.css",
    "check-types": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@infernal-ui/preset": "workspace:*",
    "@pandacss/dev": "^1.8.2",
    "solid-js": "^1.9.11",
    "typescript": "^5.9.3"
  }
}
