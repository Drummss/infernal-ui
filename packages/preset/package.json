{
  "name": "@infernal-ui/preset",
  "version": "0.1.0",
  "description": "Infernal UI Panda CSS preset, accent themes, and theme utilities.",
  "keywords": [
    "panda-css",
    "design-system",
    "theme",
    "tokens",
    "solid",
    "infernal-ui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Drummss/infernal-ui.git",
    "directory": "packages/preset"
  },
  "homepage": "https://github.com/Drummss/infernal-ui/tree/main/packages/preset#readme",
  "bugs": {
    "url": "https://github.com/Drummss/infernal-ui/issues"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsup src/index.ts --format esm --dts --watch --clean",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm run build"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.8.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
