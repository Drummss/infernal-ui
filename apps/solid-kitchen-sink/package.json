{
  "name": "solid-kitchen-sink",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "panda:generate": "panda codegen && panda cssgen --outfile styled-system/styles.css",
    "dev:panda": "node ../../scripts/run-parallel.mjs \"panda codegen --watch\" \"panda cssgen --watch --outfile styled-system/styles.css\"",
    "dev:vite": "vite",
    "dev": "node ../../scripts/run-parallel.mjs \"pnpm run dev:panda\" \"pnpm run dev:vite\"",
    "build": "pnpm run panda:generate && vite build",
    "preview": "vite preview",
    "check-types": "pnpm --filter @infernal-ui/solid build:types && tsc --noEmit"
  },
  "dependencies": {
    "@infernal-ui/solid": "workspace:*",
    "@infernal-ui/styled-system": "workspace:*",
    "@solidjs/router": "^0.15.4",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.8.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-solid": "^2.11.11"
  }
}
